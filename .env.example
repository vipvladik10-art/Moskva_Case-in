# ─── Backend ─────────────────────────────────────────────
APP_ENV=dev
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:5173

# Аутентификация API (Bearer). AUTH_ENABLED=false — полный доступ без токена (локальная разработка).
AUTH_ENABLED=true
ADMIN_API_TOKEN=dev-admin-token
VIEWER_API_TOKEN=dev-viewer-token

# Автосоздание нарядов ТО по прогнозу (фоновый опрос). false — только демо-кнопки дождя.
AUTO_MAINTENANCE_FROM_FORECAST=true
MAINTENANCE_FORECAST_INTERVAL_SEC=300

# ─── Database (PostgreSQL + PostGIS + TimescaleDB) ──────
POSTGRES_USER=asphalt
POSTGRES_PASSWORD=asphalt
POSTGRES_DB=asphalt
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://asphalt:asphalt@db:5432/asphalt

# ─── Cache ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Weather providers ──────────────────────────────────
# Получить ключи: https://openweathermap.org/api  https://www.tomorrow.io
OPENWEATHER_API_KEY=
TOMORROWIO_API_KEY=
GISMETEO_API_KEY=

# Порог вероятности осадков для "зелёного окна", 0..1
GREEN_WINDOW_PRECIP_THRESHOLD=0.3
GREEN_WINDOW_MIN_TEMP_C=5
GREEN_WINDOW_MIN_TEMP_THIN_LAYER_C=10

# ─── Frontend (Vite) ────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8001/api/v1
VITE_API_PROXY_TARGET=http://localhost:8001
VITE_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# Ключ OpenWeatherMap для тайловых слоёв на карте (осадки/облака/температура/ветер).
# Можно использовать тот же ключ что и для backend OPENWEATHER_API_KEY.
# Если не задан — слой осадков использует RainViewer (бесплатно, без ключа),
# остальные слои отключаются в UI.
VITE_OWM_API_KEY=

# Токен администратора для редактирования справочников и карты (опционально).
VITE_ADMIN_API_TOKEN=dev-admin-token
